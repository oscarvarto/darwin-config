#!/bin/bash
#Generated by JetBrains Toolbox 3.0.1.59888 at 2025-11-07T09:00:12

declare -a intellij_args=()
declare -- wait=""

for o in "$@"; do
  if [[ "$o" = "--wait" || "$o" = "-w" ]]; then
    wait="-W"
    o="--wait"
  fi
  if [[ "$o" =~ " " ]]; then
    intellij_args+=("\"$o\"")
  else
    intellij_args+=("$o")
  fi
done

open -na "/Users/oscarvarto/Applications/DataGrip.app/Contents/MacOS/datagrip" $wait --args "${intellij_args[@]}"