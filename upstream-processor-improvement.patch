-        "-lm",
-        "-lstdc++",
-        "-lLLVM",
-        "-lclang-cpp",
-        "-lcrypto",
-        "-lz",
-        "-lzstd" })
+      for(auto const &lib : {
+@DEFAULT_LIBS_INITIALIZER@      })
       {
         compiler_args.push_back(strdup(lib));
       }
